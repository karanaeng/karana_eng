{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/admindashboard",
      "destination": "/admindashboard/index.html"
    },
    {
      "source": "/admindashboard/:path*",
      "destination": "/admindashboard/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
